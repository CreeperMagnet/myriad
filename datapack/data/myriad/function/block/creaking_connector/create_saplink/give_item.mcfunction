# Gives the player a saplink with the proper data

advancement grant @s only myriad:minecraft/adventure/create_saplink

$execute if data storage myriad:temp root.name if data entity @s[predicate=!myriad:entity_properties/full_inventory] SelectedItem run return run loot give @s loot {"pools":[{rolls:1,entries:[{"type":"minecraft:loot_table","value":"myriad:technical/saplink/named",functions:[{"function":"minecraft:set_name","name":{"translate":"item.myriad.saplink.$(sapling_id)"},"target":"item_name"},{"function":"minecraft:set_custom_model_data",strings:{mode:"replace_all",values:["$(sapling_id)"]}}]}]}]}
$execute unless data storage myriad:temp root.name if data entity @s[predicate=!myriad:entity_properties/full_inventory] SelectedItem run return run loot give @s loot {"pools":[{rolls:1,entries:[{"type":"minecraft:loot_table","value":"myriad:technical/saplink/unnamed",functions:[{"function":"minecraft:set_name","name":{"translate":"item.myriad.saplink.$(sapling_id)"},"target":"item_name"},{"function":"minecraft:set_custom_model_data",strings:{mode:"replace_all",values:["$(sapling_id)"]}}]}]}]}
