execute as @n[type=minecraft:item_display,tag=myriad.gobblerift.start] run function myriad:block/gobblerift/place_seeds/initiate
playsound myriad:block.gobblerift.place block @a[distance=..16]

execute if predicate myriad:entity_properties/slots/weapon.mainhand/gobblerift_seeds run return run function myriad:technical/macros/reduce_count_and_swing {slot:"mainhand"}
function myriad:technical/macros/reduce_count_and_swing {slot:"offhand"}